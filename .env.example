# --- Optional site login (set all three to enable; leave any unset = no gate) ---
# SITE_ACCESS_EMAIL=you@example.com
# SITE_ACCESS_PASSWORD=choose-a-strong-password
# SITE_ACCESS_AUTH_SECRET=long-random-secret-use-openssl-rand-hex-32

# --- Amazon Selling Partner API (LWA) ---
# Client ID + Client Secret: Developer Central → your SP-API app → "LWA credentials"
# (Login with Amazon / LWA client identifier and client secret).
SELLING_PARTNER_APP_CLIENT_ID=
SELLING_PARTNER_APP_CLIENT_SECRET=

# Refresh token is NOT shown anywhere in Developer Central. You get it AFTER you authorize
# the app: either "self-authorization" (your own seller account) or the OAuth redirect flow.
# See: https://developer-docs.amazon.com/sp-api/docs/self-authorization
SP_API_REFRESH_TOKEN=

# Region for SP-API endpoints: na | eu | fe
SP_API_REGION=na

# Optional: pin a marketplace (e.g. US = ATVPDKIKX0DER). If omitted, the first active participation is used.
# Do NOT use: Application/Solution id (amzn1.sp.solution...), or Seller Central "Merchant Token"
# (a seller identifier shown next to each country—that is NOT a marketplace id). Use values from:
# https://developer-docs.amazon.com/sp-api/docs/marketplace-ids
# SP_API_MARKETPLACE_ID=ATVPDKIKX0DER

# --- Second seller account (BirdBeSafe) — optional; pick store on the home page ---
# Falls back to the primary SP_* / LWA vars above when a value is omitted.
# SP_BBS_SP_API_REFRESH_TOKEN=
# SP_BBS_SP_API_MARKETPLACE_ID=
# SP_BBS_SP_API_REGION=na
# SP_BBS_SELLING_PARTNER_APP_CLIENT_ID=
# SP_BBS_SELLING_PARTNER_APP_CLIENT_SECRET=
# Optional: separate Google Sheet for /costs “Sync sheet” for BirdBeSafe
# SP_BBS_SP_SKU_COSTS_SHEET_CSV_URL=
# SP_BBS_SP_SKU_COSTS_SHEET_GID=

# Cap per-SKU order metrics calls (inventory can be large). Default 25 if unset.
# Use 0 to skip these calls entirely (fast path: chart + inventory still load).
# SP_API_MAX_SKU_METRICS=25

# FBA inventory pagination: one API call per page. Default 15 pages if unset.
# SP_API_MAX_INVENTORY_PAGES=15

# /sales top table (20 SKUs): scan this many FBA SKUs (by quantity) for per-SKU Sales ranking. 0 = hide table. Default 200.
# SP_SALES_OVERVIEW_MAX_SKU_SCAN=200

# Catalog image API: one call per ASIN. Default 24 if unset (remaining rows have no thumbnail).
# Use 0 to skip Catalog API entirely (fast path).
# SP_API_MAX_ASIN_THUMBNAILS=24

# Latest GET_RESTOCK_INVENTORY_RECOMMENDATIONS_REPORT → "Amz suggest qty" column. Set 0/false/no to skip.
# SP_API_FETCH_RESTOCK_REPORT=1
# Prefer reports newer than this many hours (default 336); falls back to newest DONE if none.
# SP_API_RESTOCK_REPORT_MAX_AGE_HOURS=336

# Live dashboard server timeout (ms). Default 300000 (5 min). Max 600000 (10 min).
# If .env.local sets 120000, the dashboard will often time out (Sales + many FBA pages + optional Catalog/SKU).
# SP_API_DASHBOARD_TIMEOUT_MS=300000

# If you still see "timed out" with live data, try temporarily:
# SP_API_MAX_ASIN_THUMBNAILS=0
# SP_API_MAX_SKU_METRICS=0
# SP_API_MAX_INVENTORY_PAGES=10
# SP_API_DASHBOARD_TIMEOUT_MS=600000

# Set to 1 to expose /api/debug/sp-auth when not in development (e.g. next start).
# SP_DEBUG=1

# Set to 1 to always use built-in sample data (no Amazon calls).
# SP_API_USE_MOCK=1

# --- Dashboard inventory insights (optional) ---
# Flag SKUs when days of cover is below this (1–365). Default 14.
# SP_DASHBOARD_DAYS_OF_COVER_THRESHOLD=14

# Global FBA reorder point: flag when quantity is below this. 0 = off (use data/sku-thresholds.json per SKU).
# SP_DASHBOARD_DEFAULT_REORDER_POINT=0

# Slow mover: at least this many FBA units AND units ordered in the window ≤ max (below). Default 30.
# SP_DASHBOARD_SLOW_MOVER_MIN_STOCK=30

# Max units ordered in the selected period to still count as slow (0 = only zero orders). Example: 2 = 0–2 sales.
# SP_DASHBOARD_SLOW_MOVER_MAX_ORDERED=0

# Product table: SKUs per dashboard page (1–50000). Default 40. Set to 0 for no pagination (all SKUs in one load).
# SP_DASHBOARD_PRODUCT_PAGE_SIZE=40
# SP_DASHBOARD_PRODUCT_PAGE_SIZE=0

# Replenish alert: FBA qty ≤ this OR days of cover ≤ next (defaults 2 and 30). Override per SKU in data/sku-thresholds.json.
# SP_DASHBOARD_REPLENISH_MAX_UNITS=2
# SP_DASHBOARD_REPLENISH_MAX_DAYS_COVER=30

# Weekly inventory digest (Resend). Set recipient and https://resend.com API key.
# SP_DIGEST_EMAIL_TO=derekd@gmail.com
# You choose this secret; send it as Authorization: Bearer … or ?secret= when calling /api/cron/inventory-digest
# SP_DIGEST_CRON_SECRET=generate-a-long-random-string
# On Vercel only: set CRON_SECRET in the project — Vercel Cron sends Authorization: Bearer automatically (you can omit SP_DIGEST_CRON_SECRET for cron).
# CRON_SECRET=generate-a-long-random-string
# SP_DIGEST_MAX_SKUS=500
# SP_DIGEST_DAYS_COVER_WITHIN=14
# SP_DIGEST_PERIOD=month
# RESEND_API_KEY=re_...
# RESEND_FROM="Amazon digest <digest@your-verified-domain.com>"
# Test: curl -H "Authorization: Bearer $SP_DIGEST_CRON_SECRET" http://localhost:3000/api/cron/test-email

# --- Rough margin (optional; needs data/sku-costs.json for COGS & margin $) ---
# Referral-style % applied to per-SKU sales in the window (0–50). Default 15.
# SP_DASHBOARD_REFERRAL_FEE_PERCENT=15

# Flat FBA-style $ per unit sold in the window (same currency as sales). Default 0.
# SP_DASHBOARD_FBA_FEE_PER_UNIT=0

# Account-wide ACOS % (0–100): est. ad spend per SKU = this % × that SKU’s sales in the window. Default 22.
# SP_DASHBOARD_ESTIMATED_ACOS_PERCENT=22

# Optional: Google Sheet for /costs “Sync sheet”. Paste the normal edit link OR a publish-to-web CSV URL.
# Example: https://docs.google.com/spreadsheets/d/YOUR_ID/edit?usp=sharing
# SP_SKU_COSTS_SHEET_CSV_URL=

# Optional: sheet tab gid if not the first tab (from the URL ?gid=…).
# SP_SKU_COSTS_SHEET_GID=0

# --- Vercel Blob (SKU exclusions + unit costs on serverless) ---
# Create a Blob store in the Vercel project → Storage. Vercel injects this automatically.
# Local: run `vercel env pull` if you want the same persistence in dev.
# BLOB_READ_WRITE_TOKEN=
